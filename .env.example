# Server
PORT=5000
NODE_ENV=development # development kegunaan nya utk logging database aja

# database (pake postgresql / mysql bisa ubah ya JGN LUPA GANTI DI BAGIAN SCHEMA.PRISMA JUGA KALAU MAU UBAH)

# POSTGRESQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aplikasi-sa?connection_limit=50&pool_timeout=60&connect_timeout=10&pool_min=5"
# MYSQL
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/aplikasi-sa?connection_limit=50&pool_timeout=60&connect_timeout=10&pool_min=5"


# JWT
JWT_SECRET=" INI BEBAS  MAU DI ISI APA JUGA INI UTK KUNCI HASH"
JWT_EXPIRES_IN=24h

# QR Token
QR_TOKEN_EXPIRES_MINUTES=1